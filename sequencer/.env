# ============================================================
# L2 Sequencer Environment Configuration for the TeQoin Project
# ============================================================

# === Network Configuration ======
NODE_ENV=development

# L1 Network (Sepolia)
L1_RPC_URL=https://sepolia.infura.io/v3/0ad353e769354d7980bb706b8a014fd1
L1_WS_URL=wss://sepolia.infura.io/ws/v3/0ad353e769354d7980bb706b8a014fd1
L1_CHAIN_ID=11155111
L1_DIAMOND_ADDRESS=0x2BD57c3Ca216F0D38B18BCFD14595F12DfB13C35

# L2 Network (Local)
L2_RPC_URL=http://127.0.0.1:8545
L2_WS_URL=ws://127.0.0.1:8546
L2_CHAIN_ID=420377

L2_ENGINE_URL=http://127.0.0.1:8552
L2_JWT_SECRET_PATH=/root/optimistic-rollup/infrastructure/docker/jwt.hex

# === Contract Addresses ===
L2_TEQTOKEN_ADDRESS=0x5E3A9432a2D6eb0c5D362A0A2F58Bc02Db45850D
L2_BRIDGE_ADDRESS= 0x919aa27d5278BC98bf40BA5A79be468B91f061dA
L2_STAKING_ADDRESS=0xCab9AFC42DeC5abbFe60dfB45f669a9B855cd0B8

# === Sequencer Wallet ===
SEQUENCER_ADDRESS=0x050bf90cc79d7a4aca382b233002303fb7baa5a3
SEQUENCER_PRIVATE_KEY=45fc4ae3bad07d494e88924a10da331e3110e81401d1ab3ffdb7fbcdeb624615

# ====================Batch config===========================
BATCH_SIZE=10                # Number of L2 blocks per batch
BATCH_INTERVAL= 50         # Seconds between batches (fallback)
BATCH_GAS_LIMIT=3000000       # Gas limit for batch submission
#============================================================



# === Database Configuration ===
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=sequencer
POSTGRES_USER=sequencer
POSTGRES_PASSWORD=testnet_password
DATABASE_URL=postgresql://sequencer:testnet_password@localhost:5432/sequencer


# === Redis Configuration ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ───────────────────────────────────────────────────────
# Health Check & Monitoring
# ───────────────────────────────────────────────────────
HEALTH_CHECK_PORT=3000
METRICS_ENABLED=true

# === Sequencer Settings ===
BLOCK_TIME_MS=5000
BATCH_INTERVAL_MS=60000
BATCH_SIZE=100

# === Logging ===
LOG_LEVEL=info

