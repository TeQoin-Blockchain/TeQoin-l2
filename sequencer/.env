# ============================================================
# L2 Sequencer Environment Configuration for the TeQoin Project
# ============================================================

# === Network Configuration ======
NODE_ENV=development

# L1 Network (Sepolia)
L1_RPC_URL=https://sepolia.infura.io/v3/0ad353e769354d7980bb706b8a014fd1
L1_CHAIN_ID=11155111
L1_DIAMOND_ADDRESS=0x9C86F630F6b5bfF11fD4e19Fea02b44677A0Ff94

# L2 Network (Local)
L2_RPC_URL=http://127.0.0.1:8545
L2_WS_URL=ws://127.0.0.1:8546
L2_CHAIN_ID=420377

# === Contract Addresses ===
TEQOIN_TOKEN_ADDRESS=0x15Fb1C8F5849F931C65f1Abf5258e92173EfD786
L2_BRIDGE_ADDRESS= 0x13439C345Fe109770d29429b3BdFE927b18EeF3B
ETH_STAKING_ADDRESS=0xFCC2A963972AE464CDcEaee864293Fbdc817b137

# === Sequencer Wallet ===
SEQUENCER_ADDRESS=0x050bf90cc79d7a4aca382b233002303fb7baa5a3
SEQUENCER_PRIVATE_KEY=45fc4ae3bad07d494e88924a10da331e3110e81401d1ab3ffdb7fbcdeb624615

# ====================Batch config===========================
BATCH_SIZE=100                # Number of L2 blocks per batch
BATCH_INTERVAL=500            # Seconds between batches (fallback)
BATCH_GAS_LIMIT=3000000       # Gas limit for batch submission
#============================================================



# === Database Configuration ===
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=sequencer
POSTGRES_USER=sequencer
POSTGRES_PASSWORD=testnet_password
DATABASE_URL=postgresql://sequencer:testnet_password@localhost:5432/sequencer


# === Redis Configuration ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ───────────────────────────────────────────────────────
# Health Check & Monitoring
# ───────────────────────────────────────────────────────
HEALTH_CHECK_PORT=3000
METRICS_ENABLED=true

# === Sequencer Settings ===
BLOCK_TIME_MS=5000
BATCH_INTERVAL_MS=60000
BATCH_SIZE=100

# === Logging ===
LOG_LEVEL=info

