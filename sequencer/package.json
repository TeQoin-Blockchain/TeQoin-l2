{
  "name": "l2-sequencer",
  "version": "1.0.0",
  "description": "L2 Mvp Sequencer for TeQoin",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "clean": "rm -rf dist",
    "prestart": "npm run build",
    "db.migrate": "ts-node ./node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
    "backfill:withdrawal-finalizations": "ts-node src/scripts/backfill-withdrawal-finalizations.ts",
    "start:event-gateway": "node dist/event-gateway.js",
    "dev:event-gateway": "nodemon --exec ts-node src/event-gateway.ts"
  },
  "author": "TeQoin Team",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.0.0",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.3",
    "merkletreejs": "^0.6.0",
    "pg": "^8.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.0",
    "clear": "^0.1.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
