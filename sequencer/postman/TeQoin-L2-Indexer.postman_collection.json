{
  "info": {
    "name": "TeQoin L2 Indexer API",
    "description": "Endpoints for block explorer and wallet integration.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Blocks",
      "item": [
        {
          "name": "Get Latest Block",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/block/latest"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', function () { pm.response.to.have.status(200); });",
                  "pm.test('success true', function () { pm.expect(pm.response.json().success).to.eql(true); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Block By Number",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/block/{{blockNumber}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Block Transactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/block/{{blockNumber}}/transactions?limit=5"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Missing Block (404)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/block/999999999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('404', function () { pm.response.to.have.status(404); });",
                  "pm.test('success false', function () { pm.expect(pm.response.json().success).to.eql(false); });"
                ]
              }
            }
          ]
        }
      ]
