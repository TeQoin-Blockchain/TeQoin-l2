{
  "name": "l2-indexer",
  "version": "1.0.0",
  "description": "TeQoin L2 Transaction Indexer",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "migrate": "psql $DATABASE_URL -f src/database/migrations/001_initial.sql",
    "backfill:withdrawals": "ts-node src/scripts/backfill-missing-withdrawals.ts",
    "backfill:l1-withdrawals": "ts-node src/scripts/backfill-l1-withdrawal-lifecycle.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ethers": "^6.10.0",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "ioredis": "^5.3.2",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/compression": "^1.7.5",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
